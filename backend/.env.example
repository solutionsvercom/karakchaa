# Copy to .env — never commit .env

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# MongoDB Atlas
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/karakchaa?retryWrites=true&w=majority

# Server (Hostinger sets PORT automatically in production)
PORT=5000
NODE_ENV=development

# Public URLs (production)
APP_URL=https://karakcha.in
MENU_URL=https://karakcha.in
ADMIN_URL=https://karakcha.in/admin

# CORS — include production + local Vite ports for development
ALLOWED_ORIGINS=https://karakcha.in,https://www.karakcha.in,http://localhost:5173,http://localhost:5174,http://localhost:5000

# Rate limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=900000

SESSION_SECRET=your-session-secret

ENABLE_HELMET=true
ENABLE_CORS=true
ENABLE_RATE_LIMIT=true

LOG_LEVEL=info

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
