# ===============================
# KARAKCHAA CRM - ENVIRONMENT CONFIGURATION
# ===============================

# ---------------------------------
# JWT Configuration
# ---------------------------------
JWT_SECRET=karakchaa-super-secret-jwt-key-change-in-production-2024
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ---------------------------------
# Database
# ---------------------------------
MONGO_URI=mongodb+srv://karakchaa_admin:Ax4ZsdmR-UxX8-L@karakchaa.nkzmamw.mongodb.net/karakchaa?retryWrites=true&w=majority
# MONGO_URI="mongodb+srv://karakchaa_admin:Ax4ZsdmR-UxX8-L@karakchaa.nkzmamw.mongodb.net/karakchaa"
# MONGO_URI=mongodb://localhost:27017/karakchaa

# ---------------------------------
# Server Configuration
# ---------------------------------
PORT=5000
NODE_ENV=development

# ---------------------------------
# CORS Configuration (Frontend URLs)
# ---------------------------------
# Add your frontend URL here (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------
# Rate Limiting
# ---------------------------------
# Login attempts allowed per window
RATE_LIMIT_MAX_ATTEMPTS=5
# Window duration in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# ---------------------------------
# Session Configuration (Optional)
# ---------------------------------
SESSION_SECRET=karakchaa-session-secret-2024

# ---------------------------------
# Email Configuration (Optional - for password reset)
# ---------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ---------------------------------
# Security Features
# ---------------------------------
ENABLE_HELMET=true
ENABLE_CORS=true
ENABLE_RATE_LIMIT=true

# ---------------------------------
# Logging
# ---------------------------------
LOG_LEVEL=info

